#!/bin/zsh
# runner.sh — generated by fry for mission {{.MissionID}}
# Invoked by LaunchAgent com.fry.{{.MissionID}}

set -uo pipefail

export HOME="{{.Home}}"
export USER="{{.User}}"
export LOGNAME="{{.User}}"
export PATH="{{.Path}}"

MISSION_DIR="{{.MissionDir}}"
cd "$MISSION_DIR" || exit 1

exec {{.FryBinaryPath}} wake {{.MissionID}} >> "$MISSION_DIR/logs/cron.log" 2>&1
